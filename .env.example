# Mail API (server/send-mail-server.mjs) — copy to .env and fill secrets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=info@apexongroup.net
FROM_NAME=Apexon Group Web
TO_EMAIL=info@apexongroup.net
# Local dev default 3001. On cPanel Node, host usually injects PORT — leave unset.
MAIL_SERVER_PORT=3001

# Optional: full URL baked into client at build time (when /api is not proxied)
# VITE_MAIL_API=http://localhost:3001/api/send-mail
